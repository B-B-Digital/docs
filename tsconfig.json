// This file is not used by "docusaurus start/build" commands.
// It is here to improve your IDE experience (type-checking, autocompletion...),
// and can also run the package.json "typecheck" script manually.
//
// Not extending "@docusaurus/tsconfig" — its baseUrl compilerOption was
// removed in TypeScript 7 (TS5102). Inlined the same options here minus
// baseUrl; "paths" resolves relative to this file without it.
{
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "jsx": "preserve",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "moduleResolution": "bundler",
    "module": "esnext",
    "noEmit": true,
    "paths": {
      "@site/*": ["./*"]
    },
    "skipLibCheck": true,
    "strict": true
  },
  "exclude": [".docusaurus", "build"]
}
